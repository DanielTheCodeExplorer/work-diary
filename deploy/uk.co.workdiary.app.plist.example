<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>uk.co.workdiary.app</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/python3</string>
    <string>/absolute/path/to/work-diary/app.py</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/absolute/path/to/work-diary</string>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/tmp/work-diary.out.log</string>

  <key>StandardErrorPath</key>
  <string>/tmp/work-diary.err.log</string>
</dict>
</plist>
